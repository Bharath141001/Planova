# Docker Compose secrets — copy to .env.docker and fill real values before running
# Generate JWT secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=planova

# JWT — must be 64+ character random strings, never the defaults
JWT_SECRET=replace-with-output-of-openssl-rand-hex-64
JWT_REFRESH_SECRET=replace-with-a-different-output-of-openssl-rand-hex-64

# Frontend URL — must match exactly what users type in the browser (no trailing slash)
CLIENT_URL=https://your-frontend-domain.com

# Set true only on the very first deploy to seed demo data, then remove
SEED_DB=false
